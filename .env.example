# Access password used by middleware.js
PASSWORD=your_access_password_here

# Gemini API Key
# Vercel 推荐变量名（当前项目也兼容 VITE_GEMINI_API_KEY）
GEMINI_API_KEY=your_api_key_here

# Custom Base URL (optional)
# Vercel 推荐变量名（当前项目也兼容 VITE_GEMINI_BASE_URL）
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
